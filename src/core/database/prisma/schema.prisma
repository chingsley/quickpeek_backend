generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                           String         @id @default(uuid())
  email                        String         @unique
  password                     String
  name                         String
  username                     String         @unique
  deviceType                   String
  deviceToken                  String         // unique identifier for push notifications
  notificationsEnabled         Boolean
  locationSharingEnabled       Boolean
  isVerified                   Boolean
  profileImageUrl              String?
  createdAt                    DateTime       @default(now())
  updatedAt                    DateTime       @updatedAt

  location                     Location?
  questions                    Question[]     @relation("CreatedQuestions")
  claimedQuestions             Question[]     @relation("ClaimedQuestions")
  assignedQuestions            Question[]     @relation("AssignedQuestions")
  answers                      Answer[]
  messages                     Message[]
  reviewsGiven                 Review[]       @relation("ReviewsGiven")
  reviewsReceived              Review[]       @relation("ReviewsReceived")
  userRatings                  UserRating[]
  transactions                 Transaction[]

  @@map("users")
}

model Location {
  id                  String    @id @default(uuid())
  userId              String    @unique
  latitude            Float
  longitude           Float
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  user                User      @relation(fields: [userId], references: [id])

  @@map("locations")
}

enum QuestionStatus {
  OPEN
  ASSIGNED
  ANSWERED
  EXPIRED
  CANCELLED
}

enum ReviewerRole {
  QUESTIONER
  RESPONDER
}

enum RatingRole {
  AS_RESPONDER
  AS_QUESTIONER
}

enum MessageType {
  USER
  SYSTEM
}

model Question {
  id                      String           @id @default(uuid())
  text                    String
  longitude               Float
  latitude                Float
  address                 String
  userId                  String
  status                  QuestionStatus   @default(OPEN)
  createdAt               DateTime         @default(now())
  updatedAt               DateTime         @updatedAt
  answeredAt              DateTime?
  claimedByUserId         String?
  claimedAt               DateTime?
  assignedResponderId     String?
  assignedAt              DateTime?
  timeToRespondMs         Int?
  respondByAt             DateTime?
  expiredAt               DateTime?

  answers                 Answer[]
  messages                Message[]
  reviews                 Review[]
  user                    User             @relation("CreatedQuestions", fields: [userId], references: [id])
  claimedByUser           User?            @relation("ClaimedQuestions", fields: [claimedByUserId], references: [id])
  assignedResponder       User?            @relation("AssignedQuestions", fields: [assignedResponderId], references: [id])

  @@map("questions")
}

model Message {
  id          String      @id @default(uuid())
  questionId  String
  senderId    String
  text        String
  type        MessageType @default(USER)
  createdAt   DateTime    @default(now())
  readAt      DateTime?

  question    Question  @relation(fields: [questionId], references: [id], onDelete: Cascade)
  sender      User      @relation(fields: [senderId], references: [id])

  @@index([questionId])
  @@map("messages")
}

model Review {
  id          String        @id @default(uuid())
  questionId  String
  raterId     String
  rateeId     String
  raterRole   ReviewerRole
  stars       Int
  comment     String?
  isRevealed  Boolean       @default(false)
  createdAt   DateTime      @default(now())
  revealedAt  DateTime?

  question    Question      @relation(fields: [questionId], references: [id], onDelete: Cascade)
  rater       User          @relation("ReviewsGiven", fields: [raterId], references: [id])
  ratee       User          @relation("ReviewsReceived", fields: [rateeId], references: [id])

  @@unique([questionId, raterId])
  @@index([rateeId, isRevealed])
  @@map("reviews")
}

model Answer {
  id             String          @id @default(uuid())
  text           String
  imageUrl       String?
  questionId     String
  userId         String
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  question       Question        @relation(fields: [questionId], references: [id])
  user           User            @relation(fields: [userId], references: [id])

  @@map("answers")
}

model Transaction {
  id         String        @id @default(uuid())
  amount     Float
  userId     String
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt
  user       User          @relation(fields: [userId], references: [id])

  @@map("transactions")
}

model UserRating {
  id           String      @id @default(uuid())
  userId       String
  role         RatingRole
  totalStars   Int
  reviewsCount Int
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  user         User        @relation(fields: [userId], references: [id])

  @@unique([userId, role])
  @@map("user_ratings")
}
